# Copy this file's contents into Vercel's Project Settings -> Environment
# Variables. Never commit a real .env file with actual secrets.

# From your free Upstash Redis database (Upstash dashboard -> your database
# -> REST API section):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# The password you'll type into the hidden editor login. Pick something only
# you know - this is the only thing standing between the public and your
# admin panel.
ADMIN_PASSWORD=
